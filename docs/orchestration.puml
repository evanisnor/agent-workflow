@startuml orchestration
!theme plain
skinparam dpi 200
skinparam backgroundColor #FFFFFF
skinparam actorStyle awesome
skinparam arrowColor #555555
skinparam arrowFontSize 11
skinparam actorFontSize 12

left to right direction

actor "Planning\nAgent" as pa
actor "Task\nAgents" as ta

actor "You" as human
actor "Orchestrating\nAgent" as oa

actor "Review\nAgents" as ra
database "GitHub" as gh

human <-right-> oa : assign & approve /\npresent & escalate

oa <-up-> pa : spawn /\ndependency tree
oa <-up-> ta : spawn /\ndiff review

ta -right-> gh : PRs & CI fixes
gh <-left-> oa : CI & review events /\nPR approval

oa <-down-> ra : spawn /\nreview context

@enduml
