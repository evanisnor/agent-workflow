@startuml orchestration
!theme materia
skinparam dpi 200
skinparam backgroundColor #FFFFFF
skinparam actorStyle awesome
skinparam arrowFontSize 11
skinparam actorFontSize 12
skinparam actorFontColor #333333

top to bottom direction

actor "Planning\nAgent" as pa
actor "You" as human #2255AA

actor "Orchestrating\nAgent" as oa

actor "Task\nAgents" as ta
actor "Review\nAgents" as ra
database "GitHub" as gh

human <-[#2255AA]-> oa : "→ assign & approve\n← present & escalate"

human -[hidden]right-> pa

oa <-up-> pa : task plan

oa <-down-> ta : diff review

ta -right-> gh : PRs & CI fixes
gh -up-> oa

oa <-right-> ra : review context

@enduml
